# Airbnb Automate Configuration
# Copy this file to .env and fill in your values

# Flask settings
FLASK_SECRET_KEY=change-this-to-a-random-string
# Avoid 6000 and other Chrome-blocked ports (ERR_UNSAFE_PORT in the browser)
FLASK_PORT=5000
FLASK_DEBUG=false

# Database
DATABASE_PATH=data/airbnb_automate.db

# Browser settings
HEADLESS=true

# Outreach login (Airbnb requires login for messaging)
# A persistent browser profile is stored at data/airbnb_browser_profile by default.
# Use the "Login to Airbnb" button in the web UI to log in once -- the session persists.
#
# If Google/Apple OAuth fails in the default Chromium, use your installed Chrome:
# PLAYWRIGHT_CHANNEL=chrome
#
# Override the profile directory (or set to "none" to disable persistence -- not recommended):
# BROWSER_USER_DATA_DIR=data/airbnb_browser_profile
#
# Optional: only set if you need a specific UA; otherwise the browser default is used
# BROWSER_USER_AGENT=

# Outreach -- customize your message template (optional)
# Use {host_name}, {place_name}, and {location} as placeholders
# OUTREACH_MESSAGE=Hey {host_name}! I'd love to stay at "{place_name}" in {location}...
