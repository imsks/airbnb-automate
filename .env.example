# Airbnb Automate Configuration
# Copy this file to .env and fill in your values

# Your content creator profile
CREATOR_NAME=Your Name
CREATOR_PLATFORM=Instagram
CREATOR_HANDLE=@yourhandle
CREATOR_FOLLOWERS=10000
CREATOR_EMAIL=your@email.com
CREATOR_PORTFOLIO_URL=https://yourportfolio.com

# Optional: Email settings for sending outreach
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password

# Flask settings
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_PORT=5000

# Scheduler settings (cron-like)
# Options: daily, weekly, monthly
SCHEDULE_FREQUENCY=weekly
SCHEDULE_DAY=monday
SCHEDULE_TIME=09:00

# Database
DATABASE_PATH=data/airbnb_automate.db

# Browser settings
HEADLESS=true
SLOW_MO=100
