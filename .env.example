# Airbnb Automate Configuration
# Copy this file to .env and fill in your values

# Flask settings
FLASK_SECRET_KEY=change-this-to-a-random-string
# Avoid 6000 and other Chrome-blocked ports (ERR_UNSAFE_PORT in the browser)
FLASK_PORT=5000
FLASK_DEBUG=false

# Database
DATABASE_PATH=data/airbnb_automate.db

# Browser settings
HEADLESS=true

# Outreach login (Airbnb requires login for messaging)
# Default: persistent folder data/airbnb_browser_profile + optional data/browser_state.json backup.
# Run: pip install playwright && playwright install chrome
# Then set PLAYWRIGHT_CHANNEL=chrome (recommended for OAuth / real sites).
#
# PLAYWRIGHT_CHANNEL=chrome
# BROWSER_USER_DATA_DIR=data/airbnb_browser_profile
#
# --- Most reliable: attach to YOUR Chrome (log in manually, then run the app) ---
# 1) Quit all Chrome windows. 2) Start Chrome with debugging and its own profile, e.g. macOS:
#    /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome \
#      --remote-debugging-port=9333 \
#      --user-data-dir="$HOME/airbnb-automate-chrome"
# 3) In that window only, open airbnb.com and log in. Leave Chrome open.
# 4) In .env:
# CHROME_CDP_URL=http://127.0.0.1:9333
#
# Optional: only set if you need a specific UA
# BROWSER_USER_AGENT=

# Outreach -- customize your message template (optional)
# Use {host_name}, {place_name}, and {location} as placeholders
# OUTREACH_MESSAGE=Hey {host_name}! I'd love to stay at "{place_name}" in {location}...
